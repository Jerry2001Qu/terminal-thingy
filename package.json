{
  "name": "terminal-thingy",
  "version": "0.2.0",
  "description": "Stream your terminal to your phone",
  "type": "module",
  "bin": {
    "terminal-thingy": "./bin/terminal-thingy.js"
  },
  "scripts": {
    "postinstall": "node -e \"try{const p=require('path'),f=require('fs'),d=p.join(p.dirname(require.resolve('node-pty/package.json')),'prebuilds');if(f.existsSync(d)){const walk=dir=>{for(const e of f.readdirSync(dir,{withFileTypes:true})){const fp=p.join(dir,e.name);if(e.isDirectory())walk(fp);else if(e.name==='spawn-helper')f.chmodSync(fp,0o755)}};walk(d)}}catch(e){}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "bonjour-service": "^1.3.0",
    "commander": "^14.0.3",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
